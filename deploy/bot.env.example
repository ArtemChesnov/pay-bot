# Пример /etc/bot.env для production (скопировать на сервер и подставить значения)
# Права: chown root:botapp /etc/bot.env; chmod 640 /etc/bot.env

NODE_ENV=production
PORT=3000
DATABASE_URL=postgresql://botapp:YOUR_STRONG_PASSWORD@localhost:5432/pay_bot

TELEGRAM_BOT_TOKEN=123456789:AAH...
WEBHOOK_SECRET=длинная-случайная-строка-минимум-32-символа
WEBHOOK_BASE_URL=https://bot.example.ru

TRAINER_TELEGRAM_ID=123456789
TRAINER_USERNAME=
SELF_GROUP_ID=
INDIVIDUAL_MODE=MANUAL_GROUP
INDIVIDUAL_INVITE_EXPIRE_MINUTES=10

POLICY_VERSION=1.0
OFFER_VERSION=1.0
CRON_TZ=Europe/Moscow
INVITE_COOLDOWN_MINUTES=15
PENDING_TIMEOUT_HOURS=48
REVIEW_TIMEOUT_DAYS=7

EXECUTOR_FIO=Иванов Иван Иванович
EXECUTOR_INN=1234567890
EXECUTOR_CONTACTS=email@example.com, +7 900 123-45-67

# ЮKassa — обязательны для приёма оплаты; без них тарифы недоступны
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=https://bot.example.ru/yookassa/return
YOOKASSA_WEBHOOK_PATH=/webhooks/yookassa
YOOKASSA_WEBHOOK_IP_ALLOWLIST=
